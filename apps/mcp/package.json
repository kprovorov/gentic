    "check-types": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "test": "jest --detectOpenHandles"
  },
  "dependencies": {
    "@clerk/express": "^2.1.35",
    "@clerk/mcp-tools": "^0.5.0",
    "@gentic/services": "workspace:*",
