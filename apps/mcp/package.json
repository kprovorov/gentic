{
  "name": "@gentic/mcp",
  "version": "0.0.1",
  "description": "Gentic remote MCP server.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node dist/index.cjs",
    "dev": "tsdown --watch --onSuccess \"node dist/index.cjs\"",
