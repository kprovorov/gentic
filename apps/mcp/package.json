{
  "name": "@gentic/mcp",
  "version": "0.0.1",
  "description": "Gentic remote MCP server.",
  "type": "module",
  "private": true,
  "main": "dist/index.mjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/express": "^2.1.35",
    "@clerk/mcp-tools": "^0.5.0",
    "@gentic/services": "workspace:*",
    "@gentic/supabase": "workspace:*",
    "@gentic/validators": "workspace:*",
    "@modelcontextprotocol/sdk": "1.26.0",
    "express": "^5.2.1",
    "mcp-handler": "^1.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@gentic/eslint-config": "workspace:*",
    "@gentic/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "eslint": "^9",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.3",
    "typescript": "^5"
  }
}
