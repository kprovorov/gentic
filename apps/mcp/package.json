    "@gentic/validators": "workspace:*",
    "@modelcontextprotocol/sdk": "1.26.0",
    "express": "^5.2.1",
    "mcp-handler": "^1.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@gentic/eslint-config": "workspace:*",
    "@gentic/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "eslint": "^9",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.3",
    "typescript": "^5"
