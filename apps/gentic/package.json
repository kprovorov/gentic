{
  "name": "@gentic/gentic",
  "version": "0.4.0",
  "description": "Gentic agent: runs coding agents over the Agent Client Protocol for queued issues.",
  "type": "module",
  "private": true,
  "bin": {
    "gentic": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js run",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.55.0",
    "@agentclientprotocol/codex-acp": "^1.1.0",
    "@agentclientprotocol/sdk": "^1.1.0",
    "@clack/prompts": "^1.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "env-paths": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@gentic/eslint-config": "workspace:*",
    "@gentic/typescript-config": "workspace:*",
    "@types/node": "^20",
    "eslint": "^9",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
