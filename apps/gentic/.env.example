# Hosted Gentic API endpoint and the user's Clerk-generated API key.
GENTIC_API_URL=http://localhost:3000/api/v1
GENTIC_API_KEY=

# Base for cloning project repos (project.repo is appended, e.g. "user/repo").
GIT_REMOTE_BASE=git@github.com:

# Where fresh clones are created (one subdirectory per issue). Leave unset to
# use an OS-appropriate data directory (e.g. ~/.local/share/gentic/workspaces
# on Linux). Uncomment to override:
# WORKDIR=/tmp/gentic-workspaces

# How often (ms) to poll for issues that were moved to Todo (run_status = queued).
POLL_INTERVAL_MS=3000
