# Supabase project the agent reads/writes. Use the SERVICE ROLE key — it
# bypasses RLS, so keep it secret and only run this process somewhere trusted.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Base for cloning project repos (project.repo is appended, e.g. "user/repo").
GIT_REMOTE_BASE=git@github.com:

# Where fresh clones are created (one subdirectory per issue).
WORKDIR=/tmp/gentic-workspaces

# How often (ms) to poll for issues that were moved to Todo (run_status = queued).
POLL_INTERVAL_MS=3000
