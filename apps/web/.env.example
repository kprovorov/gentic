NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (Authentication). Get these from your Clerk application dashboard.
# Also enable the Supabase integration under Clerk Dashboard > Integrations so
# session tokens carry the `role: authenticated` claim Supabase's Data API expects.
#
# For the remote MCP server (/api/mcp), also enable Dynamic Client Registration
# under Clerk Dashboard > OAuth Applications. See docs/mcp-server/oauth-setup.md.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
