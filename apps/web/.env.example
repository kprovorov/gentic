NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Asymmetric (ES256) private JWT signing key, registered as a *standby* JWT
# signing key on the Supabase project, used to mint short-lived Realtime
# tokens for the worker (POST /api/v1/agent/realtime/token). Full private JWK
# as one-line JSON, e.g. the output of `supabase gen signing-key --algorithm
# ES256`. See docs/realtime-transport.md "JWT signing key setup".
SUPABASE_JWT_PRIVATE_KEY=

# Clerk (Authentication). Get these from your Clerk application dashboard.
# Also enable the Supabase integration under Clerk Dashboard > Integrations so
# session tokens carry the `role: authenticated` claim Supabase's Data API expects.
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Upstash Redis (REST) — shared cache for agent API-key verification so the
# worker's polling doesn't re-bill Clerk on every request (~24 verifications/day
# per token). Optional in local dev: if unset, auth falls back to verifying
# against Clerk on every request. From the Upstash console > your database > REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel AI Gateway OIDC (server-side). Used by the web app to generate issue
# titles from issue prompts. Vercel deployments provide VERCEL_OIDC_TOKEN
# automatically; for local development use `vercel env pull` or `vercel dev`.
VERCEL_OIDC_TOKEN=
ISSUE_TITLE_MODEL=openai/gpt-4.1-mini

# GitHub App integration. Use the app slug from the app URL:
# https://github.com/apps/<slug>
GITHUB_APP_SLUG=

# Webhook secret configured on the GitHub App (Settings > General > Webhook
# secret). Verifies the `X-Hub-Signature-256` header on incoming
# `pull_request` / `pull_request_review` events at
# /api/integrations/github/webhook, which move an issue's status as its PR is
# reviewed, merged, or closed.
GITHUB_WEBHOOK_SECRET=

# GitHub App ID and private key (Settings > General > App ID, and Settings >
# General > Private keys > Generate a private key). Used to mint short-lived
# installation access tokens so the webhook handler can fetch a review's
# inline comments when auto-responding to "changes requested" reviews. See
# docs/github-app.md.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
