  "keyFeatures": [
    "Create and manage coding issues assigned to AI agents (Claude Code or Codex)",
    "Background agent worker that polls for queued issues and autonomously writes code",
    "Automated pull request creation after each agent run",
    "Real-time issue status tracking through the full development lifecycle",
    "GitHub App integration for repository and PR automation",
    "File attachments on issues (images, text files) forwarded to the agent",
    "Issue blocking/dependency relations",
    "MCP server for managing issues and projects from any MCP-compatible AI client",
    "Standalone binary deployment — no Node.js required on the target machine",
    "OS-native service management (systemd on Linux, launchd on macOS)"
  ],
  "publicApiSurface": [
    "gentic auth login [--api-url <url>] [--api-key <key>]",
    "gentic auth logout [-y]",
    "gentic auth status",
